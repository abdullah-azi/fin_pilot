APP_NAME=FinPilot API
APP_ENV=development
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Local Docker Postgres from the root docker-compose.yml
DATABASE_URL=postgresql+psycopg://finpilot:finpilot@localhost:5433/finpilot

AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
# DeepSeek OpenAI-compatible endpoint. Do not append /v1.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace-me
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

GROK_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
