APP_NAME=FinPilot API
APP_ENV=development
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Local Docker Postgres from the root docker-compose.yml
DATABASE_URL=postgresql+psycopg://finpilot:finpilot@localhost:5433/finpilot
TEST_DATABASE_URL=postgresql+psycopg://finpilot:finpilot@localhost:5433/finpilot_test
DATABASE_CONNECT_TIMEOUT_SECONDS=5

AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
# DeepSeek OpenAI-compatible endpoint. Do not append /v1.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace-me
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
PASSWORD_RESET_URL_BASE=finpilot://reset-password
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=uploads
LOCAL_STORAGE_PUBLIC_BASE_URL=/uploads
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
EXPO_PUSH_BASE_URL=https://exp.host/--/api/v2/push/send
EXPO_PUSH_TIMEOUT_SECONDS=15

GROK_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
